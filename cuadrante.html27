        <tr><td data-label="Nombre">Gedi</td><td data-label="Lunes">DC</td><td data-label="Martes">T</td><td data-label="Miércoles">DC</td><td data-label="Jueves">C</td><td data-label="Viernes">C</td><td data-label="Sábado">L</td><td data-label="Domingo">L</td></tr>
